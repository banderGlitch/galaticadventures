# Base URL for the FastAPI backend.
#
# Local dev: leave it pointing at the uvicorn default (the client falls
# back to 127.0.0.1:8000 if unset, but Vite needs the var declared so the
# `import.meta.env` access typechecks).
#
# Production: set this to your Railway URL, e.g.
#   VITE_API_BASE_URL=https://asteroid-dodger-api.up.railway.app
VITE_API_BASE_URL=http://127.0.0.1:8000

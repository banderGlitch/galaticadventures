# Base URL for the FastAPI backend (no trailing slash).
#
# Local dev:
VITE_API_BASE_URL=http://127.0.0.1:8000
#
# Production — set in the Vercel dashboard (Settings → Environment Variables),
# not only in this file, then redeploy so the bundle picks it up:
#   VITE_API_BASE_URL=https://YOUR-SERVICE.up.railway.app
#
# Mini App frontend URL (for Railway CORS): https://galaticadventures.vercel.app
